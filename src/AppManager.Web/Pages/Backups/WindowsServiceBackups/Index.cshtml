@page
@model AppManager.Web.Pages.Backups.WindowsServiceBackups.IndexModel
@using Microsoft.Extensions.Localization
@using AppManager.Localization
@inject IStringLocalizer<AppManagerResource> L

@section scripts { <abp-script src="/Pages/Backups/WindowsServiceBackups/Index.js" /> }

<abp-card>
    <abp-card-header>
        <abp-row>
            <abp-column size-md="_6"><abp-card-title>@L["Backups:WindowsServiceBackups"]</abp-card-title></abp-column>
            <abp-column size-md="_6" class="text-end">
                <abp-button id="CreateBackupButton" text="@L["Backups:Create"].Value" icon="plus" button-type="Primary" />
            </abp-column>
        </abp-row>
    </abp-card-header>
    <abp-card-body>
        <abp-row class="mb-3">
            <abp-column size-md="_4"><input id="FilterInput" class="form-control" placeholder="@L["Search"]" /></abp-column>
        </abp-row>
        <abp-table striped-rows="true" id="ServiceBackupsTable" class="nowrap">
            <thead><tr><th>@L["WindowsServices:ServiceName"]</th><th>@L["WindowsServices:DisplayName"]</th><th>@L["Backups:Description"]</th><th>@L["Backups:CreatedAt"]</th><th>@L["Actions"]</th></tr></thead>
        </abp-table>
    </abp-card-body>
</abp-card>
