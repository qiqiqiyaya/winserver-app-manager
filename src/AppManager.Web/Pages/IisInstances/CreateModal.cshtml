@page
@model AppManager.Web.Pages.IisInstances.CreateModalModel
@using Microsoft.Extensions.Localization
@using AppManager.Localization
@inject IStringLocalizer<AppManagerResource> L
@{
    Layout = null;
}

<abp-modal size="Large">
    <abp-modal-header title="@L["IisInstances:Create"].Value"></abp-modal-header>
    <abp-modal-body>
        <abp-dynamic-form abp-model="Input" asp-page="/IisInstances/CreateModal">
            <abp-form-content />
            <abp-button button-type="Primary" type="submit" text="@L["Save"].Value" />
            <abp-button button-type="Secondary" type="button" data-bs-dismiss="modal" text="@L["Cancel"].Value" />
        </abp-dynamic-form>
    </abp-modal-body>
</abp-modal>